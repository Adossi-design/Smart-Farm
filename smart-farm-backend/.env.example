# Local Development
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_change_in_production
FRONTEND_URL=http://localhost:5173

# Production (Postgres)
# DATABASE_POSTGRES_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE

